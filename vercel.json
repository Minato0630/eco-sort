{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "pythonVersion": "3.12"
      }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/predict",
      "dest": "api/index.py"
    },
    {
      "src": "/$",
      "dest": "frontend/index.html"
    },
    {
      "src": "/admin$",
      "dest": "frontend/admin.html"
    },
    {
      "src": "/collector$",
      "dest": "frontend/collector.html"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "frontend/uploads/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
